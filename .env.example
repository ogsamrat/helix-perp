# ─────────────────────────────────────────────────────────────────────────────
# Helix — root environment reference. Each workspace also has its own .env.example
# (web/.env.example, keeper/.env.example). Copy what you need.
# ─────────────────────────────────────────────────────────────────────────────

# ── Stellar network ──────────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ── Deploy / scripts (stellar-cli identity alias) ────────────────────────────
# Generated + funded with: stellar keys generate helix --network testnet --fund
STELLAR_KEY_ALIAS=helix

# ── Contract ids (populated by scripts/deploy_testnet.ps1 → deploy/testnet.json)
MOCK_USDC_ID=CCZ23IOAR23RXTJPLGR3A6SD4TLBIYFU4E42YRKC2RPVX2QRPUROIKBA
MOCK_ORACLE_ID=CCIQ2IQLXN576DBZDLP6GKBBWQVYAZN2JHBGM4QQHFSVGBBKRK7W6WYZ
ORACLE_ADAPTER_ID=CCMYNSD7ZYZVVFRRNNKSSMKQQTUDXBO3TCL6GBGMF4GKIFYBCK6IMQAW
MARKET_REGISTRY_ID=CBKYVMWPQB7R3NXBJ45HVRZMIXFJ2NMRALCHLQHSVQY3MGN7D57SQZXL
COLLATERAL_VAULT_ID=CBKEHG7LINNB73UIEKZNL7ALV7KYT63JU6WLD2BVUUW5GNO7764GVI2W
PERP_ENGINE_ID=CCNRZNFFDPY7Y2YNVTLT6RLCHIRHAX5D3B5TX7F2J3PBPO6FEKNBF3RU

# ── Keeper (off-chain worker) ────────────────────────────────────────────────
# NEVER commit a real secret. Obtain via: stellar keys show helix
KEEPER_SECRET=S...your_testnet_secret...
POLL_INTERVAL_MS=60000
SIMULATE_PRICES=true

# ── Vercel deploy (GitHub Actions secrets) ───────────────────────────────────
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
