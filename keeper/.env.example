# ---------------------------------------------------------------------------
# Helix keeper configuration. Copy to `.env` and fill in.
#   cp .env.example .env
# NEVER commit a real secret. .env is gitignored.
# ---------------------------------------------------------------------------

# Keeper signing secret (Stellar secret seed, starts with "S...").
# Obtain it from the Stellar CLI for the identity you deployed/registered as keeper:
#   stellar keys show <name>
# This account MUST be registered as a keeper in the market_registry, and must
# be funded with XLM on testnet (https://friendbot.stellar.org).
KEEPER_SECRET=

# Soroban RPC + network.
RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Contract addresses (testnet). These are loaded from ../deploy/testnet.json when
# present; the values here act as fallbacks / overrides.
PERP_ENGINE_ID=CCNRZNFFDPY7Y2YNVTLT6RLCHIRHAX5D3B5TX7F2J3PBPO6FEKNBF3RU
MARKET_REGISTRY_ID=CBKYVMWPQB7R3NXBJ45HVRZMIXFJ2NMRALCHLQHSVQY3MGN7D57SQZXL
MOCK_ORACLE_ID=CCIQ2IQLXN576DBZDLP6GKBBWQVYAZN2JHBGM4QQHFSVGBBKRK7W6WYZ
ORACLE_ADAPTER_ID=CCMYNSD7ZYZVVFRRNNKSSMKQQTUDXBO3TCL6GBGMF4GKIFYBCK6IMQAW

# Loop cadence in milliseconds (default 60s).
POLL_INTERVAL_MS=60000

# Set to "true" to nudge mock-oracle prices each cycle (demo only).
SIMULATE_PRICES=true

# Optional: log level (debug | info | warn | error). Default: info.
LOG_LEVEL=info

# Optional: how many ledgers back to start indexing from on a cold start
# (no state.json). The RPC only retains a limited event history window.
EVENT_LOOKBACK_LEDGERS=17280
