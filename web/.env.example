# Helix web — environment. ALL optional: if unset, the app falls back to the
# committed src/config/deployment.json (the live testnet deployment), so it works
# out of the box. Override these on Vercel to point at a different deployment.

NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

